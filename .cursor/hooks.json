{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": "cd java-server && mvn clean compile",
        "matcher": "Write|TabWrite"
      },
      {
        "command": "cd front && pnpm run lint",
        "matcher": "Write|TabWrite"
      },
      {
        "command": "cd node-server && node --check index.js",
        "matcher": "Write|TabWrite"
      },
      {
        "command": "git rev-parse --abbrev-ref HEAD",
        "matcher": "Write|TabWrite"
      }
    ]
  }
}